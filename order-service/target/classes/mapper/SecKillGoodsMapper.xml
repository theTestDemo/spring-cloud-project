<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.orderservice.mapper.SecKillGoodsMapper">
    <select id="selectValidSecKillGoods" resultType="com.example.orderservice.entity.SeckillGoods">
        <![CDATA[
        SELECT id, goods_id, seckill_price, stock
        FROM seckill_goods
        WHERE stock > 0 AND start_time <= NOW() AND end_time >= NOW()
        ]]>
    </select>
    <insert id="insertSecKillOrder">
        INSERT INTO seckill_order (user_id, goods_id)
        VALUES (#{userId}, #{goodsId})
    </insert>
</mapper>