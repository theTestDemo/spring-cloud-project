<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.userservice.mapper.UserMapper">
    <select id="findById" resultType="com.example.userservice.entity.User">
        SELECT id, username, password, email, created_time as createdTime
        FROM user
        WHERE id = #{id}
    </select>
    <select id="username" resultType="com.example.userservice.entity.User">
        select *
        from user
        where username = #{username}
    </select>
    <insert id="register">
        insert into user(username,password,email) value(#{username},#{password},#{email})
    </insert>
    <select id="findUsername" resultType="com.example.userservice.entity.User">
        select id from user where username = #{username}
    </select>
    <select id="login" resultType="com.example.userservice.entity.User">
        select id,username,password from user where username = #{username}
    </select>
    <select id="reviewUserInfo" resultType="com.example.userservice.entity.User">
        SELECT id, username
        FROM user
        WHERE id IN
        <foreach collection="userIds" item="id" open="(" close=")" separator=",">
            #{id}
        </foreach>
    </select>

</mapper>